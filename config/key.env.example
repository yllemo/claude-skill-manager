# Kopiera till key.env och fyll i värden. Filen key.env ska inte checkas in.
# Format: NYCKEL=värde (en per rad, # för kommentarer)

OPENAI_API_KEY=

# Valfria bas-URL:er (överskrider config/ai.php). Anrop sker från PHP-servern.
# Ollama: om PHP körs på samma PC som Ollama, lämna tomt eller använd http://127.0.0.1:11434/v1
# Om PHP körs på en annan maskin som kan nå din Ollama-värd (LAN/VPN), sätt t.ex.:
# OLLAMA_BASE=http://192.168.50.50:11434/v1
# På Ollama-värden: lyssna på LAN (t.ex. OLLAMA_HOST=0.0.0.0) och öppna brandvägg för 11434.
# Om PHP ligger på internet utan väg till ditt LAN: använd VPN/Tailscale/ngrok mot Ollama.
# OPENAI_BASE=https://api.openai.com/v1
# LMSTUDIO_BASE=http://127.0.0.1:1234/v1
OLLAMA_BASE=
